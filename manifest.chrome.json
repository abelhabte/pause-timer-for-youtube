{
  "manifest_version": 3,
  "name": "Pause Timer for YouTube",
  "version": "2.0",
  "description": "Timer that pauses YouTube videos by entering the timestamp or percentage",
  "icons": {
    "16": "icons/logo_16.png",
    "48": "icons/logo_32.png",
    "64": "icons/logo_64.png",
    "128": "icons/logo_128.png"
  },
  "action": {
    "default_title": "Pause Timer for YouTube",
    "default_icon": "icons/logo_128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://music.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://music.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/pause.svg"],
      "matches": ["https://www.youtube.com/*", "https://music.youtube.com/*"]
    }
  ]
}
